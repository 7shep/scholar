{
  "name": "school-organizer",
  "productName": "Scholar",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop planner for courses, assignments, and grades.",
  "author": "7shep",
  "repository": {
    "type": "git",
    "url": "https://github.com/7shep/school-organizer.git"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:app": "wait-on tcp:5173 file:dist/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dist": "npm run build && electron-builder --publish never",
    "release": "npm run build && electron-builder --publish always",
    "release:mac": "npm run build && electron-builder --mac dmg zip --publish always",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "start": "npm run build && electron ."
  },
  "build": {
    "appId": "com.shep.scholar",
    "productName": "Scholar",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "7shep",
        "repo": "school-organizer",
        "releaseType": "draft"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.516.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
